{
	"name": "cuekit-workspace",
	"private": true,
	"type": "module",
	"workspaces": [
		"packages/*"
	],
	"bin": {
		"cuekit": "bin/cuekit.js"
	},
	"scripts": {
		"bundle": "bun build packages/cli/src/bin.ts --target=bun --outdir=bin --entry-naming=cuekit.js",
		"release:check": "bun run scripts/release-check.ts",
		"build": "bun run --filter '*' build",
		"typecheck": "bun run --filter '*' typecheck",
		"test": "bun test",
		"check": "biome check .",
		"fix": "biome check --write .",
		"docs:dev": "vitepress dev site",
		"docs:build": "vitepress build site",
		"docs:preview": "vitepress preview site"
	},
	"optionalDependencies": {
		"@opentui/core-darwin-arm64": "0.2.1",
		"@opentui/core-darwin-x64": "0.2.1",
		"@opentui/core-linux-arm64": "0.2.1",
		"@opentui/core-linux-x64": "0.2.1",
		"@opentui/core-win32-arm64": "0.2.1",
		"@opentui/core-win32-x64": "0.2.1"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.0.0",
		"@types/bun": "latest",
		"typescript": "^5.8.0",
		"vitepress": "1.6.4"
	},
	"engines": {
		"bun": ">=1.2.0"
	}
}
